MEDICAL_RAG_HOST=127.0.0.1
MEDICAL_RAG_PORT=8000
MEDICAL_RAG_DATABASE=artifacts/demo/medicalrag.sqlite3
MEDICAL_RAG_ARTIFACT_ROOT=artifacts
MEDICAL_RAG_CORS_ORIGINS=http://localhost:5173
MEDICAL_RAG_MAX_CONCURRENCY=2

# Core generator (Gemini free-tier project; never put real keys in git).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Independent LLM judge and optional robustness model.
GROQ_API_KEY=
GROQ_JUDGE_MODEL=openai/gpt-oss-120b
GROQ_GENERATOR_MODEL=openai/gpt-oss-20b

# Optional paid robustness only. Leave empty for the $0 core protocol.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
