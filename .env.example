# Optional absolute state directory. If empty, backend/data is used.
MEDICAL_RAG_DATA_DIR=
MEDICAL_RAG_CORS_ORIGINS=http://localhost:5173
MEDICAL_RAG_MAX_CONCURRENCY=2
MEDICAL_RAG_GENERATOR=mock

# OpenAI-compatible gateway. Never put a real key in git.
OPENAI_BASE_URL=https://api.futureppo.top/v1
OPENAI_API_KEY=
GATEWAY_GENERATOR_MODEL=deepseek-v3.2
GATEWAY_JUDGE_MODEL=cerebras/gpt-oss-120b
